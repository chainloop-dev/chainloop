FROM golang:1.26.5@sha256:079e59808d2d252516e27e3f3a9c003740dee7f75e55aa71528766d52bcfc16a AS builder
RUN mkdir -p /.config/chainloop

FROM scratch

COPY ./chainloop /
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder --chown=1001:1001 /.config/chainloop /.config/chainloop

USER 1001

ENTRYPOINT [ "./chainloop"]
